--- mlme.c.orig	2026-04-28 19:17:22.999992174 -0600
+++ mlme.c	2026-05-02 10:02:33.709987620 -0600
@@ -23,6 +23,16 @@
 #include <linux/slab.h>
 #include <linux/export.h>
 #include <net/mac80211.h>
+
+static unsigned int skip_mcs_check = 0;
+module_param(skip_mcs_check, uint, 0644);
+MODULE_PARM_DESC(skip_mcs_check, "Bitmask to bypass MCS verification (1=HT, 2=VHT, 4=HE, 8=EHT)");
+
+#define MCS_SKIP_HT  (1 << 0)
+#define MCS_SKIP_VHT (1 << 1)
+#define MCS_SKIP_HE  (1 << 2)
+#define MCS_SKIP_EHT (1 << 3)
+
 #include <linux/unaligned.h>
 
 #include "ieee80211_i.h"
@@ -428,6 +438,8 @@
 	struct ieee80211_sta_ht_cap sta_ht_cap;
 	int i;
 
+	if (skip_mcs_check & MCS_SKIP_HT) return true;
+
 	if (sband->band == NL80211_BAND_6GHZ)
 		return true;
 
@@ -468,6 +480,8 @@
 	u16 ap_min_req_set, sta_rx_mcs_map, sta_tx_mcs_map;
 	int nss;
 
+	if (skip_mcs_check & MCS_SKIP_VHT) return true;
+
 	if (sband->band != NL80211_BAND_5GHZ)
 		return true;
 
@@ -540,6 +554,8 @@
 	u16 ap_min_req_set;
 	int nss;
 
+	if (skip_mcs_check & MCS_SKIP_HE) return true;
+
 	if (!he_cap)
 		return false;
 
@@ -625,6 +641,8 @@
 	u16 ap_min_req_set;
 	int i;
 
+	if (skip_mcs_check & MCS_SKIP_HE) return true;
+
 	if (!sta_he_cap || !he_op)
 		return false;
 
@@ -743,6 +761,8 @@
 	const struct ieee80211_eht_mcs_nss_supp_20mhz_only *req;
 	unsigned int i;
 
+	if (skip_mcs_check & MCS_SKIP_EHT) return true;
+
 	if (!sta_he_cap || !sta_eht_cap || !eht_op)
 		return false;
 
